<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Banking Suite">


    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <test name="TestCases">

        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>

        <classes>
            <class name="testcases.AddAccountTest"/>
            <class name="testcases.TransactionTest"/>
            <class name="testcases.WithdrawalTest"/>
        </classes>

    </test>

</suite>
